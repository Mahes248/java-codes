public class OddIndex {
    public static void main(String[]args) {
        int[]arr={1,2,3,4,5};
        System.out.println("odd Index");
        for(int i=0;i<arr.length;i++)
        {
            if(i%2==1)
            System.out.println(arr[i]+" ");
        }
        System.out.println();
        System.out.println("Even Index");
        for(int i=0;i<arr.length;i++)
        {
            if(i%2==0)
            {
                System.out.println(arr[i]+" ");
            }
        }
    }
}
                
            
            
        
    
