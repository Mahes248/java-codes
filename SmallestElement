public class smallestElement {
    public static void main(String[]args) {
        int[]arr={10,20,30,40,50};
        int Max=arr[0];
        for(int i=0;i<arr.length;i++)
        {
            if(arr[i]<Max)
            {
                Max=arr[i];
            }
        }
        System.out.println("Smallest Element:"+Max);
    }
}
